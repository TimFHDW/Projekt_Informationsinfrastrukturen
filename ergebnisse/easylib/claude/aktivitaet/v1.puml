@startuml EasyLib-Aktivitaetsdiagramm
' EasyLib - Aktivitaetsdiagramm (KI: Claude, Prompt v1)
' Szenario: Bibliothekar pflegt ein neues Buchexemplar ein
skinparam shadowing false
title Bibliothekar pflegt ein neues Buchexemplar ein

|Bibliothekar|
start
:Einpflegen eines neuen Buchexemplars starten;
:ISBN bzw. Buchdaten erfassen;

|EasyLib-System|
:Verbundkatalog abfragen;

|Verbundkatalog|
:Suchanfrage bearbeiten;
:Suchergebnis zurückliefern;

|EasyLib-System|
if (Buchdaten im Verbundkatalog gefunden?) then (ja)
  :Buchdaten importieren;
else (nein)
  |Bibliothekar|
  :Buchdaten manuell eingeben;
  |EasyLib-System|
endif
:Prüfen, ob Werk bereits im Bestand existiert;
if (Werk bereits im Bestand?) then (ja)
  :Bestehendes Werk auswählen;
else (nein)
  :Werk (Buch) neu anlegen;
endif
:Exemplar anlegen;

|Bibliothekar|
:Standort zuweisen (Etage, Regalnummer);

|EasyLib-System|
:Exemplar mit Standort speichern;
:Bestätigung anzeigen;
stop
@enduml
